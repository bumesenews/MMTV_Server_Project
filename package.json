{
  "name": "football-live-streaming-backend",
  "version": "1.0.0",
  "description": "Production football live streaming backend for Flutter — fixtures, stream extraction, GitHub JSON delivery",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "scrape": "node src/cli/runPipeline.js",
    "admin:seed": "node src/cli/seedAdmin.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop football-streaming",
    "pm2:restart": "pm2 restart football-streaming",
    "pm2:logs": "pm2 logs football-streaming"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^13.10.0",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.5.0",
    "node-cron": "^3.0.3",
    "puppeteer": "^23.11.1",
    "winston": "^3.17.0"
  },
  "keywords": [
    "football",
    "streaming",
    "scraper",
    "flutter",
    "fotmob"
  ],
  "license": "UNLICENSED",
  "private": true
}
